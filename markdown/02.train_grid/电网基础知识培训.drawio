  <diagram name="有功无功视在功率" id="active-reactive-apparent-power">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="有功、无功、视在功率对比" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="480" y="20" width="500" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="subtitle" value="推车工作模型" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16" vertex="1" parent="1">
          <mxGeometry x="580" y="80" width="280" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="activeBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="400" height="180" as="geometry" />
        </mxCell>
        <mxCell id="activeTitle" value="有功功率 (P)" style="text;html=1;strokeColor=none;fillColor=#82b366;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="140" y="155" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="activeArrow" value="──────────────▶" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="140" y="200" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="activeDesc" value="推车前进（真正做功）&lt;br&gt;• 重物位移，产生实际效益&lt;br&gt;• 转化为机械能、热能、光能&lt;br&gt;• 单位：千瓦 (kW)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="80" y="240" width="360" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="reactiveBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=3" vertex="1" parent="1">
          <mxGeometry x="500" y="140" width="400" height="180" as="geometry" />
        </mxCell>
        <mxCell id="reactiveTitle" value="无功功率 (Q)" style="text;html=1;strokeColor=none;fillColor=#d6b656;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="580" y="155" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="reactiveArrow" value="↔ ⟷ ↔" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="580" y="200" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="reactiveDesc" value="维持平衡（不直接做功）&lt;br&gt;• 电感/电容储能-放能循环&lt;br&gt;• 建立磁场/电场，维持电压&lt;br&gt;• 单位：千乏 (kvar)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="520" y="240" width="360" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="apparentBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=3" vertex="1" parent="1">
          <mxGeometry x="940" y="140" width="400" height="180" as="geometry" />
        </mxCell>
        <mxCell id="apparentTitle" value="视在功率 (S)" style="text;html=1;strokeColor=none;fillColor=#6c8ebf;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="1020" y="155" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="apparentSymbol" value="工人总体能力" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="1020" y="200" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="apparentDesc" value="设备额定容量能力&lt;br&gt;• 能提供的最大能量&lt;br&gt;• S = √(P² + Q²)&lt;br&gt;• 单位：千伏安 (kVA)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="960" y="240" width="360" height="70" as="geometry" />
        </mxCell>
        
        <mxCell id="pfTitle" value="功率因数 (cosφ)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="560" y="360" width="340" height="30" as="geometry" />
        </mxCell>
        <mxCell id="pfFormula" value="cosφ = P / S = 推车工作占总能力的比例" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="350" y="410" width="760" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="triangleTitle" value="功率三角形" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="480" y="480" width="200" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="triP" value="P（有功）" style="text;html=1;strokeColor=none;fillColor=#d5e8d4;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="350" y="650" width="100" height="35" as="geometry" />
        </mxCell>
        <mxCell id="triQ" value="Q（无功）" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="750" y="530" width="100" height="35" as="geometry" />
        </mxCell>
        <mxCell id="triS" value="S（视在）" style="text;html=1;strokeColor=none;fillColor=#dae8fc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="750" y="630" width="100" height="35" as="geometry" />
        </mxCell>
        <mxCell id="phi" value="φ" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="680" y="640" width="40" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="note" value="说明：无功功率虽不直接做功，但电网运行必需。电感建立磁场（如变压器、电机），电容建立电场，维持电压稳定和系统正常运行。" style="text;html=1;strokeColor=#9673a6;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="150" y="730" width="1100" height="35" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
